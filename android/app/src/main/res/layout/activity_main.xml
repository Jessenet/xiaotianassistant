<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="小天AI助手"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- 语音唤醒控制 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_wakeup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#E3F2FD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎤 语音唤醒"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_wakeup_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未启动"
                        android:textSize="13sp"
                        android:textColor="#1565C0" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_wakeup"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="启动语音唤醒"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    app:icon="@android:drawable/ic_media_play"
                    app:iconGravity="start"
                    app:iconSize="18dp" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="说 &quot;你好小天&quot; 唤醒助手"
                    android:textSize="11sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 音乐APP + 无障碍服务 水平排列 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- 音乐APP选择 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_app_selection"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#E8F5E9">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🎵 音乐APP"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_selected_app"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="当前: QQ音乐"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_select_app"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text="切换"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 无障碍服务状态 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_accessibility"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFF3E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="♿ 无障碍服务"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_accessibility_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="未启用"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_accessibility"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text="启用"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 状态 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 状态"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="准备就绪"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 识别结果 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬 识别结果"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待语音输入..."
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:minHeight="48dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 语音按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_voice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🎙️ 开始语音输入"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <!-- 支持指令 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F5F5F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 支持指令"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_instructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🗣️ 唤醒：说 &quot;你好小天&quot;\n🎵 播放：&quot;播放周杰伦的稻香&quot;\n⏸️ 暂停：&quot;暂停音乐&quot;\n⏭️ 切歌：&quot;下一首&quot; / &quot;上一首&quot;\n🔊 音量：&quot;音量调到50&quot; / &quot;大声一点&quot;\n▶️ 继续：&quot;继续播放&quot;"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#424242" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
